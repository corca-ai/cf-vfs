{
  "name": "@corca-ai/cf-vfs",
  "version": "0.1.0",
  "description": "A tree-shakable virtual filesystem for Cloudflare Durable Objects and R2",
  "license": "MIT",
  "author": "corca-ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corca-ai/cf-vfs.git"
  },
  "bugs": {
    "url": "https://github.com/corca-ai/cf-vfs/issues"
  },
  "homepage": "https://github.com/corca-ai/cf-vfs#readme",
  "keywords": [
    "cloudflare",
    "durable-objects",
    "r2",
    "sqlite",
    "virtual-filesystem"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "import": "./dist/commands/index.js"
    },
    "./commands/*": {
      "types": "./dist/commands/*.d.ts",
      "import": "./dist/commands/*.js"
    },
    "./storage/do-sql": {
      "types": "./dist/storage/do-sql.d.ts",
      "import": "./dist/storage/do-sql.js"
    },
    "./storage/r2": {
      "types": "./dist/storage/r2.d.ts",
      "import": "./dist/storage/r2.js"
    },
    "./durable-object": {
      "types": "./dist/durable-object.d.ts",
      "import": "./dist/durable-object.js"
    },
    "./regex/native": {
      "types": "./dist/regex/native.d.ts",
      "import": "./dist/regex/native.js"
    },
    "./testing": {
      "types": "./dist/testing/memory.d.ts",
      "import": "./dist/testing/memory.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check",
    "typegen": "wrangler types worker-configuration.d.ts --config wrangler.test.jsonc --env-interface VfsTestEnv --include-runtime false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:docs": "node test/check-docs.mjs",
    "test:package": "node test/check-package.mjs",
    "test:tree-shaking": "node test/check-tree-shaking.mjs",
    "check": "npm run typegen && npm run build && npm run typecheck && npm test && npm run test:docs && npm run test:package && npm run test:tree-shaking"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260719.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
