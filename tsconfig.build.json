{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["es2022", "webworker"],
    "types": ["@cloudflare/workers-types"],
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["test", "dist"]
}
